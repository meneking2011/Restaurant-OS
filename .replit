modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "restaurant-os-web"

[[workflows.workflow]]
name = "restaurant-os-web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=23008 BASE_PATH=/ pnpm --filter @workspace/restaurant-os run dev"
waitForPort = 23008

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
